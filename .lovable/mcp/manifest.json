    "tools": [
      {
        "name": "list_brands",
        "title": "Listar marcas",
        "description": "Lista as marcas (workspaces/brands do vocabulário AEIOU) que o usuário autenticado pode acessar. Respeita RLS e time. Cada item traz `deep_link` para o Creator.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "description": "Máximo de marcas a retornar. Padrão 50."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_brand",
        "title": "Detalhar marca",
        "description": "Retorna dados completos de uma marca (identidade visual, valores, restrições, moodboard) e o resumo de estilo aprendido a partir do feedback (`brand_style_preferences`). Use antes de criar entregáveis (caption/imagem) para o orquestrador montar briefings coerentes.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "brand_id": {
              "type": "string",
              "format": "uuid",
              "description": "ID da marca."
            }
          },
          "required": [
            "brand_id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
