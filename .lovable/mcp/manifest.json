      {
        "name": "list_deliverables",
        "title": "Listar entregáveis",
        "description": "Lista os entregáveis recentes do usuário (conteúdos, revisões, planos, vídeos). Corresponde à tabela `actions`. Cada item traz `deep_link` para abrir no Creator.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
